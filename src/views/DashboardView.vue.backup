<template>
  <div class="flex flex-col h-full overflow-hidden" style="gap: var(--gap);">
    <!-- Greeting Row -->
    <div class="flex-shrink-0 flex items-center justify-between">
      <div class="flex flex-col gap-0.5">
        <h1 style="font: var(--font-title); color: var(--text-primary);">Good {{ timeOfDay }}, Dr. {{ therapistLastName }}</h1>
        <p style="font: var(--font-body); color: var(--text-secondary);">Here's your practice overview</p>
      </div>
      <div class="flex items-center gap-1.5">
        <Calendar :size="14" style="color: var(--text-muted);" />
        <span style="font: var(--font-small); color: var(--text-muted);">{{ todayDate }}</span>
      </div>
    </div>

    <!-- Stat Cards Row -->
    <div class="flex-shrink-0 grid grid-cols-4" style="gap: var(--gap);">
      <div
        v-for="stat in stats"
        :key="stat.id"
        class="card-shadow flex items-center"
        style="background: var(--bg-card); border-radius: var(--radius-lg); padding: var(--padding-card); gap: 14px;"
      >
        <div
          class="flex items-center justify-center flex-shrink-0"
          :class="stat.gradientClass"
          style="width: 48px; height: 48px; border-radius: var(--radius-md);"
        >
          <component :is="stat.icon" :size="24" style="color: var(--text-on-primary);" />
        </div>
        <div class="flex flex-col" style="gap: 2px;">
          <p style="font: var(--font-title); color: var(--text-primary); line-height: 1;">{{ stat.value }}</p>
          <p style="font: var(--font-small); color: var(--text-muted); margin-top: 2px;">{{ stat.label }}</p>
          <p :style="{ font: 'var(--font-small)', color: stat.trendColor }">{{ stat.trend }}</p>
        </div>
      </div>
    </div>

    <!-- Bottom Grid -->
    <div class="flex-1 min-h-0 grid" style="grid-template-columns: 1fr 280px; gap: var(--gap);">
      <!-- Left: Patient Table -->
      <div class="h-full flex flex-col overflow-hidden card-shadow" style="background: var(--bg-card); border-radius: var(--radius-lg);">
        <!-- Table header bar -->
        <div class="flex-shrink-0 px-4 flex items-center gap-2.5" style="height: 48px; border-bottom: 1px solid var(--border);">
          <h2 style="font: var(--font-section); color: var(--text-primary);">Active Patients</h2>
          <div class="ml-auto flex items-center gap-2">
            <div class="relative">
              <Search :size="16" class="absolute left-2.5 top-1/2 -translate-y-1/2" style="color: var(--text-muted);" />
              <input
                v-model="searchQuery"
                type="text"
                placeholder="Search patients..."
                class="pl-8 pr-3 text-sm focus:outline-none"
                style="width: 180px; height: 36px; background: var(--primary-light); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary);"
                @input="filterPatients"
              />
            </div>
            <select
              v-model="statusFilter"
              class="px-2.5 text-sm focus:outline-none"
              style="height: 36px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: white; color: var(--text-primary);"
              @change="filterPatients"
            >
              <option value="all">All Status</option>
              <option value="active">Active</option>
              <option value="needs_attention">Needs Attention</option>
              <option value="inactive">Inactive</option>
            </select>
            <button class="px-3 text-sm font-medium gradient-primary" style="height: 36px; border-radius: var(--radius-sm); color: var(--text-on-primary); border: none; cursor: pointer;">
              Add Patient
            </button>
          </div>
        </div>
        
        <!-- Column headers -->
        <div class="flex-shrink-0 px-4 flex items-center" style="height: 40px; background: var(--bg-hover); border-bottom: 1px solid var(--border);">
          <div style="width: 28%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted);">PATIENT</div>
          <div style="width: 20%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted);">CONDITION</div>
          <div style="width: 18%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted);">LAST SESSION</div>
          <div style="width: 16%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted);">ADHERENCE</div>
          <div style="width: 10%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted);">STATUS</div>
          <div style="width: 8%; font: var(--font-label); text-transform: uppercase; color: var(--text-muted); text-align: right;">ACTIONS</div>
        </div>
        
        <!-- Table body -->
        <div class="flex-1 overflow-y-auto min-h-0">
          <div v-if="isLoading" class="flex justify-center items-center h-full">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2" style="border-color: var(--primary);"></div>
          </div>
          
          <div v-else-if="paginatedPatients.length === 0" class="flex items-center justify-center h-full">
            <p style="font: var(--font-body); color: var(--text-secondary);">No patients found</p>
          </div>
          
          <div
            v-else
            v-for="patient in paginatedPatients"
            :key="patient.id"
            class="px-4 flex items-center cursor-pointer transition-all duration-150"
            style="height: 56px; border-bottom: 1px solid var(--border);"
            @click="viewPatient(patient.id)"
            @mouseenter="(e) => e.currentTarget.style.background = 'var(--bg-table-row-hover)'"
            @mouseleave="(e) => e.currentTarget.style.background = 'transparent'"
          >
            <!-- Patient Cell -->
            <div class="flex items-center gap-2" style="width: 28%;">
              <img
                v-if="patient.avatar_url"
                :src="patient.avatar_url"
                class="w-9 h-9 rounded-full object-cover flex-shrink-0"
              />
              <div v-else class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 gradient-primary" style="color: var(--text-on-primary);">
                {{ getInitials(patient.name) }}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate" style="color: var(--text-primary);">{{ patient.name }}</p>
                <p class="text-xs truncate" style="color: var(--text-muted);">{{ patient.email }}</p>
              </div>
            </div>
            
            <!-- Condition -->
            <div class="text-sm" style="width: 20%; color: var(--text-secondary);">{{ patient.condition }}</div>
            
            <!-- Last Session -->
            <div style="width: 18%;">
              <div v-if="patient.last_session" class="flex items-center gap-1">
                <Calendar :size="14" style="color: var(--text-muted);" />
                <span class="text-xs" style="color: var(--text-secondary);">{{ formatDate(patient.last_session) }}</span>
              </div>
              <span v-else class="text-xs italic" style="color: var(--text-muted);">No sessions</span>
            </div>
            
            <!-- Adherence -->
            <div class="flex items-center gap-2" style="width: 16%;">
              <div class="overflow-hidden" style="width: 68px; height: 8px; background: #E5E7EB; border-radius: var(--radius-pill);">
                <div
                  class="h-full transition-all duration-300"
                  :style="{ 
                    width: `${patient.adherence_rate}%`,
                    background: getAdherenceGradient(patient.adherence_rate)
                  }"
                ></div>
              </div>
              <span class="text-xs font-semibold" style="color: var(--text-primary);">{{ patient.adherence_rate }}%</span>
            </div>
            
            <!-- Status -->
            <div style="width: 10%;">
              <span :style="getBadgeStyle(patient.status)">
                {{ formatStatus(patient.status) }}
              </span>
            </div>
            
            <!-- Actions -->
            <div class="text-right" style="width: 8%;">
              <button
                class="px-3 text-sm font-medium transition-all duration-150"
                style="height: 36px; background: var(--primary-light); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--primary); cursor: pointer;"
                @click.stop="viewPatient(patient.id)"
                @mouseenter="(e) => { e.currentTarget.style.background = 'var(--gradient-primary)'; e.currentTarget.style.color = 'var(--text-on-primary)'; e.currentTarget.style.border = 'none'; }"
                @mouseleave="(e) => { e.currentTarget.style.background = 'var(--primary-light)'; e.currentTarget.style.color = 'var(--primary)'; e.currentTarget.style.border = '1px solid var(--border)'; }"
              >
                View
              </button>
            </div>
          </div>
        </div>
        
        <!-- Pagination -->
        <div class="flex-shrink-0 px-4 flex items-center justify-between" style="height: 40px; border-top: 1px solid var(--border);">
          <span class="text-xs" style="color: var(--text-secondary);">
            Showing {{ ((currentPage - 1) * perPage) + 1 }} to {{ Math.min(currentPage * perPage, filteredPatients.length) }} of {{ filteredPatients.length }} patients
          </span>
          <div class="flex gap-2">
            <button
              class="px-3 text-sm font-medium transition-colors"
              :class="currentPage === 1 ? 'opacity-40 cursor-not-allowed' : ''"
              style="height: 36px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: white;"
              :disabled="currentPage === 1"
              @click="currentPage--"
            >
              Previous
            </button>
            <button
              class="px-3 text-sm font-medium transition-colors"
              :class="currentPage >= totalPages ? 'opacity-40 cursor-not-allowed' : ''"
              style="height: 36px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: white;"
              :disabled="currentPage >= totalPages"
              @click="currentPage++"
            >
              Next
            </button>
          </div>
        </div>
      </div>

      <!-- Right: Widgets Column -->
      <div class="h-full flex flex-col overflow-hidden" style="gap: var(--gap);">
        <!-- Widget 1: Quick Actions -->
        <div class="flex-shrink-0 card-shadow" style="background: var(--bg-card); border-radius: var(--radius-lg); padding: var(--padding-card);">
          <h3 style="font: var(--font-section); color: var(--text-primary); margin-bottom: 12px;">Quick Actions</h3>
          <div class="flex flex-col" style="gap: 8px;">
            <button class="quick-action-btn w-full text-sm flex items-center gap-2 px-3 font-medium transition-all duration-150">
              <UserPlus :size="16" />
              <span>Add New Patient</span>
            </button>
            <button class="quick-action-btn w-full text-sm flex items-center gap-2 px-3 font-medium transition-all duration-150">
              <ClipboardList :size="16" />
              <span>Assign Exercise</span>
            </button>
            <button class="quick-action-btn w-full text-sm flex items-center gap-2 px-3 font-medium transition-all duration-150">
              <FileText :size="16" />
              <span>Generate Report</span>
            </button>
            <button class="quick-action-btn w-full text-sm flex items-center gap-2 px-3 font-medium transition-all duration-150">
              <Bell :size="16" />
              <span>View Alerts</span>
            </button>
          </div>
        </div>

        <!-- Widget 2: Recent Alerts -->
        <div class="flex-1 min-h-0 flex flex-col overflow-hidden card-shadow" style="background: var(--bg-card); border-radius: var(--radius-lg); padding: var(--padding-card);">
          <div class="flex-shrink-0 flex items-center justify-between" style="margin-bottom: 12px;">
            <h3 style="font: var(--font-section); color: var(--text-primary);">Recent Alerts</h3>
            <a href="#" class="text-xs" style="color: var(--text-link);">View All</a>
          </div>
          <div class="flex-1 overflow-y-auto min-h-0">
            <div v-if="recentAlerts.length > 0" class="space-y-2">
              <div
                v-for="alert in recentAlerts"
                :key="alert.id"
                class="flex items-center gap-2"
              >
                <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" :class="alert.dotColor"></div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs truncate" style="color: var(--text-secondary);">{{ alert.message }}</p>
                  <p class="text-xs" style="color: var(--text-muted);">{{ alert.patient }}</p>
                </div>
                <span class="text-xs flex-shrink-0" style="color: var(--text-muted);">{{ alert.time }}</span>
              </div>
            </div>
            <div v-else class="flex items-center justify-center h-full">
              <p class="text-xs" style="color: var(--text-muted);">No alerts</p>
            </div>
          </div>
        </div>

        <!-- Widget 3: Today's Sessions -->
        <div class="flex-1 min-h-0 flex flex-col overflow-hidden card-shadow" style="background: var(--bg-card); border-radius: var(--radius-lg); padding: var(--padding-card);">
          <div class="flex-shrink-0 flex items-center justify-between" style="margin-bottom: 12px;">
            <h3 style="font: var(--font-section); color: var(--text-primary);">Today's Sessions</h3>
            <span class="text-xs" style="color: var(--text-muted);">{{ todayDate }}</span>
          </div>
          <div class="flex-1 overflow-y-auto min-h-0">
            <div v-if="todaySessions.length > 0" class="space-y-2">
              <div
                v-for="session in todaySessions"
                :key="session.id"
                class="flex items-center gap-2"
              >
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 gradient-primary" style="color: var(--text-on-primary);">
                  {{ session.initials }}
                </div>
                <span class="text-xs font-semibold" style="color: var(--text-primary);">{{ session.name }}</span>
                <span class="text-xs ml-auto" style="color: var(--text-muted);">{{ session.time }}</span>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 flex-shrink-0"></div>
              </div>
            </div>
            <div v-else class="flex flex-col items-center justify-center h-full">
              <Calendar :size="32" class="mb-2" style="color: #E5E7EB;" />
              <p class="text-xs" style="color: var(--text-muted);">No sessions today</p>
            </div>
          </div>
        </div>

        <!-- Widget 4: Adherence Overview -->
        <div class="flex-shrink-0 card-shadow" style="background: var(--bg-card); border-radius: var(--radius-lg); padding: var(--padding-card);">
          <h3 style="font: var(--font-section); color: var(--text-primary); margin-bottom: 12px;">Patient Adherence Overview</h3>
          <div class="flex flex-col" style="gap: 8px;">
            <div class="flex items-center justify-between">
              <span class="text-xs" style="color: var(--text-secondary);">High Adherence (≥75%)</span>
              <span class="h-6 text-xs font-semibold px-2 rounded-full flex items-center" style="background: var(--status-active-bg); color: var(--status-active-text);">{{ adherenceStats.high }}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs" style="color: var(--text-secondary);">Moderate (50-74%)</span>
              <span class="h-6 text-xs font-semibold px-2 rounded-full flex items-center" style="background: var(--status-warning-bg); color: var(--status-warning-text);">{{ adherenceStats.moderate }}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs" style="color: var(--text-secondary);">Low Adherence (<50%)</span>
              <span class="h-6 text-xs font-semibold px-2 rounded-full flex items-center" style="background: var(--status-danger-bg); color: var(--status-danger-text);">{{ adherenceStats.low }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, computed, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { Users, Activity, ClipboardList, BellDot, Search, Calendar, UserPlus, FileText, Bell } from 'lucide-vue-next'
import { useAuthStore } from '@/stores/authStore'
import { usePatientStore } from '@/stores/patientStore'
import { useAlertStore } from '@/stores/alertStore'
import { storeToRefs } from 'pinia'

const router = useRouter()
const authStore = useAuthStore()
const patientStore = usePatientStore()
const alertStore = useAlertStore()

const { therapistProfile } = storeToRefs(authStore)
const { patients, isLoading } = storeToRefs(patientStore)
const { unreadCount } = storeToRefs(alertStore)

const searchQuery = ref('')
const statusFilter = ref('all')
const currentPage = ref(1)
const perPage = 8

const timeOfDay = computed(() => {
  const hour = new Date().getHours()
  if (hour < 12) return 'morning'
  if (hour < 18) return 'afternoon'
  return 'evening'
})

const therapistLastName = computed(() => {
  const fullName = therapistProfile.value?.name || 'Therapist'
  const parts = fullName.split(' ')
  return parts.length > 1 ? parts[parts.length - 1] : parts[0]
})

const todayDate = computed(() => {
  return new Date().toLocaleDateString('en-US', { 
    month: 'short', 
    day: 'numeric', 
    year: 'numeric' 
  })
})

const stats = computed(() => {
  const totalPatients = patients.value.length
  const sessionsToday = patients.value.filter(p => p.last_session === new Date().toISOString().split('T')[0]).length
  const pendingReviews = patients.value.filter(p => p.status === 'needs_attention').length
  const alerts = unreadCount.value

  return [
    {
      id: 1,
      icon: Users,
      value: totalPatients,
      label: 'Total Active Patients',
      gradientClass: 'gradient-primary',
      trend: '↑ 2 this week',
      trendColor: '#10B981'
    },
    {
      id: 2,
      icon: Activity,
      value: sessionsToday,
      label: 'Sessions Today',
      gradientClass: 'gradient-success',
      trend: '— No change',
      trendColor: '#6B7280'
    },
    {
      id: 3,
      icon: ClipboardList,
      value: pendingReviews,
      label: 'Pending Reviews',
      gradientClass: 'gradient-info',
      trend: '↑ 1 this week',
      trendColor: '#10B981'
    },
    {
      id: 4,
      icon: BellDot,
      value: alerts,
      label: 'Unread Alerts',
      gradientClass: 'gradient-warning',
      trend: '— No change',
      trendColor: '#6B7280'
    }
  ]
})

const recentAlerts = computed(() => [
  {
    id: 1,
    message: 'Missed 2 consecutive sessions',
    patient: 'Sarah Johnson',
    time: '2h ago',
    dotColor: 'bg-red-500'
  },
  {
    id: 2,
    message: 'Low adherence rate detected',
    patient: 'Michael Chen',
    time: '4h ago',
    dotColor: 'bg-amber-500'
  },
  {
    id: 3,
    message: 'Exercise completion delayed',
    patient: 'Emma Davis',
    time: '6h ago',
    dotColor: 'bg-amber-500'
  }
])

const todaySessions = computed(() => [
  {
    id: 1,
    name: 'Sarah Johnson',
    initials: 'SJ',
    time: '9:00 AM'
  },
  {
    id: 2,
    name: 'Michael Chen',
    initials: 'MC',
    time: '10:30 AM'
  },
  {
    id: 3,
    name: 'Emma Davis',
    initials: 'ED',
    time: '2:00 PM'
  },
  {
    id: 4,
    name: 'James Wilson',
    initials: 'JW',
    time: '3:30 PM'
  }
])

const adherenceStats = computed(() => {
  const high = patients.value.filter(p => p.adherence_rate >= 75).length
  const moderate = patients.value.filter(p => p.adherence_rate >= 50 && p.adherence_rate < 75).length
  const low = patients.value.filter(p => p.adherence_rate < 50).length

  return { high, moderate, low }
})

const filteredPatients = computed(() => {
  let result = patients.value

  if (statusFilter.value !== 'all') {
    result = result.filter(p => p.status === statusFilter.value)
  }

  if (searchQuery.value) {
    const query = searchQuery.value.toLowerCase()
    result = result.filter(p =>
      p.name.toLowerCase().includes(query) ||
      p.email.toLowerCase().includes(query)
    )
  }

  return result
})

const totalPages = computed(() => Math.ceil(filteredPatients.value.length / perPage))

const paginatedPatients = computed(() => {
  const start = (currentPage.value - 1) * perPage
  return filteredPatients.value.slice(start, start + perPage)
})

const filterPatients = () => {
  currentPage.value = 1
}

const getInitials = (name: string) => {
  return name
    .split(' ')
    .map(n => n[0])
    .join('')
    .toUpperCase()
    .slice(0, 2)
}

const formatDate = (date?: string) => {
  if (!date) return 'No sessions'
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
}

const formatStatus = (status: string) => {
  return status.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
}

const getBadgeStyle = (status: string) => {
  const base = {
    height: '24px',
    fontSize: '12px',
    fontWeight: '600',
    borderRadius: 'var(--radius-pill)',
    padding: '0 8px',
    display: 'inline-flex',
    alignItems: 'center'
  }
  if (status === 'active') return { ...base, background: 'var(--status-active-bg)', color: 'var(--status-active-text)' }
  if (status === 'needs_attention') return { ...base, background: 'var(--status-warning-bg)', color: 'var(--status-warning-text)' }
  return { ...base, background: 'var(--status-resolved-bg)', color: 'var(--status-resolved-text)' }
}

const getAdherenceGradient = (rate: number) => {
  if (rate < 50) return 'var(--gradient-danger)'
  if (rate < 75) return 'var(--gradient-warning)'
  return 'var(--gradient-success)'
}

const viewPatient = (id: string) => {
  router.push(`/patients/${id}`)
}

onMounted(async () => {
  await patientStore.fetchPatients()
  await alertStore.fetchAlerts({ resolved: false })
})
</script>

<style scoped>
.quick-action-btn {
  height: 40px;
  background: var(--primary-light);
  border: none;
  border-radius: var(--radius-sm);
  color: var(--primary);
  cursor: pointer;
}

.quick-action-btn:hover {
  background: var(--gradient-primary);
  color: var(--text-on-primary);
}
</style>
